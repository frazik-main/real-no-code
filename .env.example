# Copy this file to .env and fill in only the values you need.
# The app loads .env through spring.config.import in application.properties.

SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:h2:mem:realnocode;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.H2Dialect
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop
SPRING_JPA_SHOW_SQL=false

SPRING_H2_CONSOLE_ENABLED=true
SPRING_H2_CONSOLE_PATH=/h2-console

AI_DEFAULT_PROVIDER=copilot
AI_TIMEOUT_SECONDS=300

AI_COPILOT_COMMAND=copilot

AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
AI_GEMINI_MODEL=gemini-2.0-flash
AI_GEMINI_API_KEY=

AI_LM_STUDIO_BASE_URL=http://localhost:1234
AI_LM_STUDIO_MODEL=local-model

